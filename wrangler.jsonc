{
  // Static-assets Worker: serves the Astro static build in ./dist.
  // No "main" — this app has no server-side code, so there is no _worker.js.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "milkyway-tracker",
  "compatibility_date": "2026-07-13",
  "assets": {
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}
