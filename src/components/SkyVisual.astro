---
// Crude "what to expect tonight" sky visual. The canvas is drawn by the page
// client script (see index.astro) using the core track for the selected night.
---
<section class="card">
  <h2>Sky tonight — core path</h2>
  <canvas id="sky-canvas" width="900" height="360" role="img"
    aria-label="Diagram of the Milky Way core path across the night sky"></canvas>
  <div class="legend">
    <span><span class="swatch" style="background:#ff6b57"></span>Core path (brighter = higher/clearer)</span>
    <span><span class="swatch" style="background:#334;"></span>Horizon haze zone (&lt;10&deg;)</span>
    <span><span class="swatch" style="background:#cfe0ff"></span>Peak position</span>
  </div>
</section>
